# Job Radar Environment Variables
# Copy to .env and fill in your credentials

# Database (default: local SQLite)
DATABASE_URL=sqlite+aiosqlite:///data/job_radar.db

# Telegram Bot (get token from @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=  # Comma-separated chat IDs (e.g., -1001234567890,123456789)

# Discord Webhook (create in Server Settings > Integrations > Webhooks)
DISCORD_WEBHOOK_URL=

# Email (SMTP)
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=  # Your email
EMAIL_PASSWORD=  # App password (not regular password)
EMAIL_FROM=Job Radar <your-email@gmail.com>
EMAIL_RECIPIENTS=  # Comma-separated recipients

# iMessage (macOS only)
# Uses imsg CLI or AppleScript - no env vars needed, just configure recipients in config.yaml
IMESSAGE_RECIPIENTS=  # Comma-separated phone numbers or emails

# Scheduler
CHECK_INTERVAL_HOURS=2
QUIET_HOURS_START=22:00
QUIET_HOURS_END=06:00
TIMEZONE=America/Los_Angeles

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/job_radar.log